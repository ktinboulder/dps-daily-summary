# ─────────────────────────────────────────────────────────
#  DPS Daily School Summary — Credential Configuration
#  Copy this file to ".env" and fill in your values.
#  Keep .env private — never share or commit it.
# ─────────────────────────────────────────────────────────

# ── DPS Infinite Campus Login ─────────────────────────────
# Your parent/guardian portal username and password
DPS_USERNAME=your_ic_username_here
DPS_PASSWORD=your_ic_password_here

# ── Gmail Settings ────────────────────────────────────────
# The Gmail account that SENDS the summary email.
# Use a Gmail App Password (NOT your main Gmail password).
#
# How to create an App Password:
#   1. Go to https://myaccount.google.com/security
#   2. Enable 2-Step Verification if not already on
#   3. Search "App passwords" → create one for "Mail"
#   4. Paste the 16-character code below (no spaces)
GMAIL_EMAIL=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ── Summary Recipient ─────────────────────────────────────
# Where the daily email should be delivered (comma-separated for multiple)
RECIPIENT_EMAIL=you@gmail.com

# ── Student Names ─────────────────────────────────────────
# STUDENT_NAME: shown in the email subject and header
# STUDENT_TARGET_NAME: full name as it appears in the portal (used to
#   select the correct student on multi-student accounts)
STUDENT_NAME=your_childs_name_here
STUDENT_TARGET_NAME=your_childs_full_portal_name_here
